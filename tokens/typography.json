{
  "font": {
    "family": {
      "display": { "$value": "'Bricolage Grotesque', sans-serif", "$type": "fontFamily" },
      "body":    { "$value": "'Plus Jakarta Sans', sans-serif",   "$type": "fontFamily" }
    },
    "weight": {
      "light":     { "$value": 300, "$type": "fontWeight" },
      "regular":   { "$value": 400, "$type": "fontWeight" },
      "medium":    { "$value": 500, "$type": "fontWeight" },
      "semibold":  { "$value": 600, "$type": "fontWeight" },
      "bold":      { "$value": 700, "$type": "fontWeight" },
      "extrabold": { "$value": 800, "$type": "fontWeight" }
    },
    "size": {
      "xs":   { "$value": "10.5px", "$type": "dimension" },
      "sm":   { "$value": "12.5px", "$type": "dimension" },
      "base": { "$value": "14px",   "$type": "dimension" },
      "md":   { "$value": "15px",   "$type": "dimension" },
      "lg":   { "$value": "17px",   "$type": "dimension" },
      "xl":   { "$value": "18px",   "$type": "dimension" },
      "2xl":         { "$value": "20px",   "$type": "dimension" },
      "display-min": { "$value": "2.5rem", "$type": "dimension" },
      "display-max": { "$value": "4.5rem", "$type": "dimension" }
    },
    "line-height": {
      "tight":   { "$value": 1.06, "$type": "number" },
      "snug":    { "$value": 1.3,  "$type": "number" },
      "normal":  { "$value": 1.65, "$type": "number" },
      "relaxed": { "$value": 1.75, "$type": "number" }
    },
    "letter-spacing": {
      "tight":   { "$value": "-0.03em", "$type": "string" },
      "display": { "$value": "-0.01em", "$type": "string" },
      "label":   { "$value": "0.05em",  "$type": "string" },
      "wide":    { "$value": "0.2em",   "$type": "string" },
      "wider":   { "$value": "0.22em",  "$type": "string" }
    }
  }
}
